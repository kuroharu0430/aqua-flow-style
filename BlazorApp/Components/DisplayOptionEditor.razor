@using BlazorApp.EntityFramework.Models
@using BlazorApp._state

<div class="display-option-editor">
    <div class="option-row">
        <label class="sticky-label">列数:</label>
        <input class="aqua-input" type="number" @bind="Section.ColumnNumber" maxlength="4" />

        <label class ="sticky-label">行数:</label>
        <input class="aqua-input" type="number" @bind="Section.RowNumber" maxlength="4" />

        <label class="sticky-label">セル幅:</label>
        <input class="aqua-input" type="number" @bind="Section.WidthPerCell" maxlength="4" />

        <label class="sticky-label">セル高さ:</label>
        <input class="aqua-input" type="number" @bind="Section.HeightPerCell" maxlength="4" />
@* 
        <label class="sticky-label">画面幅:</label>
        <input class="aqua-input" type="number" @bind="Section.ScreenWidth" maxlength="4" />

        <label class="sticky-label">画面高さ:</label>
        <input class="aqua-input" type="number" @bind="Section.ScreenHeight" maxlength="4" /> *@
    </div>
</div>

@code {
    [Parameter] public LayoutSection Section { get; set; } = new();

    // 値が変わったことを親に通知するためのコールバック
    [Parameter] public EventCallback<LayoutSection> DisplayParameterChanged { get; set; }

    private async Task NotifyChange()
    {
        if (DisplayParameterChanged.HasDelegate)
        {
            await DisplayParameterChanged.InvokeAsync(Section);
        }
    }

}